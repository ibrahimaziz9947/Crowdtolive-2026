NODE_ENV=development
PORT=4000
APP_NAME=CrowdToLive API
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=change-this-admin-jwt-secret
JWT_EXPIRES_IN=1d
ADMIN_AUTH_COOKIE_NAME=crowdtolive_admin_token
ADMIN_SEED_EMAIL=admin@crowdtolive.com
ADMIN_SEED_PASSWORD=Admin@123456
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/crowdtolive?retryWrites=true&w=majority&appName=Cluster0
